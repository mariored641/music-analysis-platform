      <note><pitch><step>G</step><octave>5</octave></pitch><duration>20</duration><type>quarter</type></note>
      <note><pitch><step>E</step><octave>5</octave></pitch><duration>20</duration><type>quarter</type></note>
      <note><pitch><step>C</step><octave>5</octave></pitch><duration>20</duration><type>quarter</type></note>
