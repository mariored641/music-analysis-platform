      <note>
        <pitch><step>F</step><octave>5</octave></pitch><duration>8</duration><type>eighth</type>
        <time-modification><actual-notes>3</actual-notes><normal-notes>2</normal-notes></time-modification>
        <beam number="1">begin</beam>
        <notations><tuplet type="start" bracket="yes" number="1"/></notations>
      </note>
      <note>
        <pitch><step>G</step><octave>5</octave></pitch><duration>8</duration><type>eighth</type>
        <time-modification><actual-notes>3</actual-notes><normal-notes>2</normal-notes></time-modification>
        <beam number="1">continue</beam>
      </note>
      <note>
        <pitch><step>A</step><octave>5</octave></pitch><duration>8</duration><type>eighth</type>
