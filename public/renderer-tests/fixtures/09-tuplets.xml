    </measure>
    <!-- Measure 2: triplet quarter notes (3 in space of 2 beats) -->
    <!-- triplet quarter = 12*2/3 = 8 units -->
    <measure number="2">
      <note>
        <pitch><step>C</step><octave>5</octave></pitch><duration>8</duration><type>quarter</type>
        <time-modification><actual-notes>3</actual-notes><normal-notes>2</normal-notes></time-modification>
