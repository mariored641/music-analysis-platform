        <key><fifths>0</fifths><mode>major</mode></key>
        <time><beats>4</beats><beat-type>4</beat-type></time>
        <clef><sign>G</sign><line>2</line></clef>
      </attributes>
      <!-- Beat 1: triplet -->
      <note>
        <pitch><step>C</step><octave>5</octave></pitch><duration>8</duration><type>eighth</type>
        <time-modification><actual-notes>3</actual-notes><normal-notes>2</normal-notes></time-modification>
        <beam number="1">begin</beam>
        <notations><tuplet type="start" bracket="yes" number="1"/></notations>
      </note>
      <note>
        <pitch><step>D</step><octave>5</octave></pitch><duration>8</duration><type>eighth</type>
        <time-modification><actual-notes>3</actual-notes><normal-notes>2</normal-notes></time-modification>
        <beam number="1">continue</beam>
