{
  "name": "map-music-analysis-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:r": "npm run test:r:capture && npm run test:r:compare",
    "test:r:capture": "npx playwright test renderer-tests/capture.spec.ts",
    "test:r:compare": "npx tsx renderer-tests/scripts/compare.ts",
    "test:r:report": "npx tsx renderer-tests/scripts/compare.ts && npx tsx renderer-tests/scripts/report.ts",
    "test:r:update": "npx tsx renderer-tests/scripts/update-refs.ts",
    "test:r:update:all": "npx tsx renderer-tests/scripts/update-refs.ts --all",
    "test:r:refs": "npx tsx renderer-tests/scripts/generate-refs-playwright.ts",
    "test:r:layer2": "npx playwright test renderer-tests/app-integration.spec.ts",
    "test:r:compare-layers": "npx tsx renderer-tests/scripts/compare-layers.ts",
    "test:r:structural": "npx tsx renderer-tests/structural/runStructural.ts --all",
    "test:r:structural:donnalee": "npx tsx renderer-tests/structural/runStructural.ts --donnalee --verbose",
    "test:r:extract": "npx tsx renderer-tests/scripts/extract-reference-data.ts",
    "test:r:pipeline": "npx tsx renderer-tests/pipeline/run.ts --all",
    "test:r:pipeline:h": "npx tsx renderer-tests/pipeline/run.ts --stage=B --all",
    "test:r:pipeline:v": "npx tsx renderer-tests/pipeline/run.ts --stage=C --all",
    "test:r:pipeline:verbose": "npx tsx renderer-tests/pipeline/run.ts --all --verbose",
    "test:r:gaps": "npx tsx renderer-tests/pipeline/run.ts --gaps"
  },
  "dependencies": {
    "i18next": "^25.0.0",
    "idb": "^8.0.3",
    "immer": "^11.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.0.0",
    "tone": "^15.0.4",
    "uuid": "^11.0.0",
    "verovio": "^6.1.0",
    "webmscore": "^1.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xmldom/xmldom": "^0.9.9",
    "linkedom": "^0.18.12",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
